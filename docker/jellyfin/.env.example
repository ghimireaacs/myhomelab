# Jellyfin config and cache — persistent across updates
JELLYFIN_CONFIG_PATH=/path/to/docker-configs/jellyfin/config
JELLYFIN_CACHE_PATH=/path/to/docker-configs/jellyfin/cache

# Media libraries — read-only mounts
MEDIA_MOVIES_PATH=/path/to/downloads/Movies
MEDIA_TV_PATH=/path/to/downloads/TV
MEDIA_AUDIOBOOKS_PATH=/path/to/downloads/audiobooks
MEDIA_PODCASTS_PATH=/path/to/downloads/podcasts
MEDIA_YOUTUBE_PATH=/path/to/downloads/Youtube
