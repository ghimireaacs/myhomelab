# Domain
DOMAIN_NAME=your-domain.com
POSTIZ_SUBDOMAIN=postiz

# Timezone
TZ=Australia/Sydney

# Secrets — generate with: openssl rand -hex 32
POSTIZ_DB_PASSWORD=change-me
POSTIZ_JWT_SECRET=change-me
POSTIZ_TEMPORAL_DB_PASSWORD=change-me

# Storage — NFS paths
POSTIZ_CONFIG_PATH=/path/to/docker-configs/postiz
POSTIZ_UPLOADS_PATH=/path/to/docker-data/postiz/uploads

# Postgres + Redis + Temporal + Elasticsearch — LOCAL disk only, never NFS
POSTIZ_DB_PATH=/local/path/to/postiz-postgres
POSTIZ_REDIS_PATH=/local/path/to/postiz-redis
POSTIZ_TEMPORAL_DB_PATH=/local/path/to/postiz-temporal-postgres
POSTIZ_ES_PATH=/local/path/to/postiz-elasticsearch

# Authentik SSO — set POSTIZ_GENERIC_OAUTH=true in compose env to enable
POSTIZ_OAUTH_CLIENT_ID=
POSTIZ_OAUTH_CLIENT_SECRET=

# Social media API keys — leave blank, configure per-platform in Postiz UI
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
