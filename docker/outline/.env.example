# Outline
SUBDOMAIN=outline
DOMAIN_NAME=your-domain.com
TZ=your-timezone

# Generate both with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32
UTILS_SECRET=generate-with-openssl-rand-hex-32

# Postgres — local disk on ghostgpu (NOT NFS)
OUTLINE_POSTGRES_PASSWORD=strong-password-here
OUTLINE_POSTGRES_PATH=/path/to/local-disk/outline/postgres

# Outline file uploads — NFS
OUTLINE_DATA_PATH=/path/to/docker-data/outline/data

# SMTP — email magic link auth
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=outline@your-domain.com
SMTP_SECURE=false
