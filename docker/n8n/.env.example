# Domain settings
DOMAIN_NAME=example.com
SUBDOMAIN=n8n

# Timezone
GENERIC_TIMEZONE=Australia/Sydney
TZ=Australia/Sydney

# OpenAI API key (optional)
OPENAI_API_KEY=

# Data paths — keep N8N_DATA_PATH on LOCAL disk, not NFS (SQLite + NFS = timeouts)
N8N_DATA_PATH=/local/path/to/n8n-data
N8N_FILES_PATH=/path/to/automation-files
