# Public URL (used by the browser to reach the app)
APP_URL=https://resume.your-domain.com

# Browserless token — any random string
BROWSERLESS_TOKEN=change-me-random-token

# Auth secret — generate with: openssl rand -hex 32
AUTH_SECRET=change-me-openssl-rand-hex-32

# Postgres — same credentials as your existing postgres instance
POSTGRES_HOST=your-postgres-container-name
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# NFS bind mount path for resume data
RXRESUME_DATA_PATH=/path/to/nfs/rxresume/data

