apiVersion: apps/v1
kind: Deployment
metadata:
  name: forgejo-runner
  namespace: personal
spec:
  replicas: 1
  selector:
    matchLabels:
      app: forgejo-runner
  template:
    metadata:
      labels:
        app: forgejo-runner
    spec:
      initContainers:
        - name: register
          image: data.forgejo.org/forgejo/runner:12
          command: ["sh", "/config/register.sh"]
          env:
            - name: RUNNER_TOKEN
              valueFrom:
                secretKeyRef:
                  name: forgejo-runner-secret
                  key: token
            - name: FORGEJO_URL
              value: https://git.${BASE_DOMAIN}
          volumeMounts:
            - name: runner-data
              mountPath: /data
            - name: runner-config
              mountPath: /config
      containers:
        - name: runner
          image: data.forgejo.org/forgejo/runner:12
          command: ["sh", "-c", "until [ -S /var/run/docker.sock ]; do sleep 1; done && forgejo-runner daemon --config /config/config.yml"]
          securityContext:
            runAsUser: 0
          env:
            - name: DOCKER_HOST
              value: unix:///var/run/docker.sock
          volumeMounts:
            - name: runner-data
              mountPath: /data
            - name: runner-config
              mountPath: /config
            - name: runner-cache
              mountPath: /cache
            - name: docker-socket
              mountPath: /var/run
        - name: dind
          image: docker:dind
          securityContext:
            privileged: true
          env:
            - name: DOCKER_TLS_CERTDIR
              value: ""
          volumeMounts:
            - name: docker-socket
              mountPath: /var/run
            - name: runner-cache
              mountPath: /cache
      volumes:
        - name: runner-data
          persistentVolumeClaim:
            claimName: forgejo-runner-pvc
        - name: runner-config
          configMap:
            name: forgejo-runner-config
        - name: docker-socket
          emptyDir: {}
        - name: runner-cache
          emptyDir: {}
