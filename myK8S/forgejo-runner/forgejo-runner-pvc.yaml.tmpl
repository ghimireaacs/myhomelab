apiVersion: v1
kind: PersistentVolume
metadata:
  name: forgejo-runner-pv
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  nfs:
    server: ${NFS_SERVER_IP}
    path: ${NFS_FORGEJO_RUNNER_PATH}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: forgejo-runner-pvc
  namespace: personal
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: forgejo-runner-pv
  resources:
    requests:
      storage: 1Gi
