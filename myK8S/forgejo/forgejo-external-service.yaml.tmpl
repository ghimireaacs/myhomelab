apiVersion: v1
kind: Service
metadata:
  name: forgejo-http
  namespace: personal
spec:
  ports:
    - port: 3000
      targetPort: 3000
---
apiVersion: v1
kind: Endpoints
metadata:
  name: forgejo-http
  namespace: personal
subsets:
  - addresses:
      - ip: ${UTILITY_IP}
    ports:
      - port: 3000
